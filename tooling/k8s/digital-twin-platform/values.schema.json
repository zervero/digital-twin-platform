{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "digital-twin-platform values",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "namespace",
    "image",
    "bff",
    "web"
  ],
  "properties": {
    "namespace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "create": {
          "type": "boolean"
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry",
        "pullPolicy"
      ],
      "properties": {
        "registry": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      }
    },
    "bff": {
      "$ref": "#/$defs/workload"
    },
    "web": {
      "$ref": "#/$defs/workload"
    },
    "global": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ingress",
        "certManager"
      ],
      "properties": {
        "ingress": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "enabled",
            "className",
            "hosts"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "className": {
              "type": "string",
              "minLength": 1
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "hosts": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "host",
                  "paths"
                ],
                "properties": {
                  "host": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^([a-z0-9]([-a-z0-9]*[a-z0-9])?\\.)+[a-z]{2,}$"
                  },
                  "paths": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": [
                        "path",
                        "pathType"
                      ],
                      "properties": {
                        "path": {
                          "type": "string",
                          "minLength": 1,
                          "pattern": "^/"
                        },
                        "pathType": {
                          "type": "string",
                          "enum": [
                            "Exact",
                            "Prefix",
                            "ImplementationSpecific"
                          ]
                        }
                      }
                    }
                  }
                }
              }
            },
            "tls": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "hosts",
                  "secretName"
                ],
                "properties": {
                  "hosts": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "secretName": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "certManager": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "staging": {
              "type": "boolean"
            },
            "email": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "workload": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "enabled",
        "replicaCount",
        "image",
        "service",
        "resources",
        "config",
        "probes",
        "serviceAccount"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "repository"
          ],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string"
            }
          }
        },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "port"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "ClusterIP",
                "NodePort",
                "LoadBalancer"
              ]
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          }
        },
        "resources": {
          "$ref": "#/$defs/resources"
        },
        "config": {
          "type": "object"
        },
        "probes": {
          "$ref": "#/$defs/probes"
        },
        "serviceAccount": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "create": {
              "type": "boolean"
            },
            "name": {
              "type": "string"
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requests",
        "limits"
      ],
      "properties": {
        "requests": {
          "$ref": "#/$defs/cpuMem"
        },
        "limits": {
          "$ref": "#/$defs/cpuMem"
        }
      }
    },
    "cpuMem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu",
        "memory"
      ],
      "properties": {
        "cpu": {
          "type": "string",
          "pattern": "^([0-9]+m|[0-9]+(\\.[0-9]+)?)$"
        },
        "memory": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?(Mi|Gi|Ki|M|G|K)?$"
        }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "liveness": {
          "$ref": "#/$defs/probe"
        },
        "readiness": {
          "$ref": "#/$defs/probe"
        }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^/"
        },
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 0
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
