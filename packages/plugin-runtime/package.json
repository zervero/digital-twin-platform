{
  "name": "@dt/plugin-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "mkdir -p dist && echo 'plugin-runtime exports types only in V1' > dist/.gitkeep",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dt/contracts": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
