{
  "name": "@dt/engine-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom",
    "typecheck": "tsc --noEmit",
    "build": "mkdir -p dist && echo 'engine-sdk is type-only at V1, three is bundled by consumer' > dist/.gitkeep",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@dt/contracts": "workspace:*",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.5",
    "typescript": "^5.6.3"
  }
}
