    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dt/contracts": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.6.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
