{
  "name": "@dt/ui-kit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles": {
      "style": "./dist/tokens.css",
      "default": "./dist/tokens.css"
    }
  },
  "scripts": {
    "test": "echo 'ui-kit has component tests in app-shell e2e'",
    "typecheck": "vue-tsc --noEmit",
    "build": "mkdir -p dist && cp src/styles/tokens.css dist/tokens.css && echo 'ui-kit: Vue SFCs consumed as source + tokens.css copied to dist/' > dist/.gitkeep",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dt/contracts": "workspace:*",
    "lucide-vue-next": "^1.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.6.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}