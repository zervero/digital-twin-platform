{
  "name": "@dt/app-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "echo 'app-shell is integration-tested in the web app'",
    "typecheck": "vue-tsc --noEmit",
    "build": "mkdir -p dist && echo 'app-shell is bundled by apps/web, no separate JS build in V1' > dist/.gitkeep",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dt/api-client": "workspace:*",
    "@dt/contracts": "workspace:*",
    "@dt/device-domain": "workspace:*",
    "@dt/engine-sdk": "workspace:*",
    "@dt/scene-domain": "workspace:*",
    "@dt/ui-kit": "workspace:*",
    "pinia": "^2.2.6"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.6.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
