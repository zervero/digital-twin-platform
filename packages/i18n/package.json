{
  "name": "@dt/i18n",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "mkdir -p dist && echo 'i18n is type-only, no JS build needed (locales are imported as JSON)' > dist/.gitkeep",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@dt/contracts": "workspace:*"
  },
  "peerDependencies": {
    "pinia": "^2.2.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vitest": "^2.1.5",
    "typescript": "^5.6.3"
  }
}
