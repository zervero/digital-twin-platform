# Auto-detect text files, normalize to LF
* text=auto eol=lf

# Force LF on common source files
*.ts         text eol=lf
*.tsx        text eol=lf
*.vue        text eol=lf
*.js         text eol=lf
*.cjs        text eol=lf
*.mjs        text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.rs         text eol=lf
*.toml       text eol=lf
*.css        text eol=lf
*.scss       text eol=lf
*.html       text eol=lf

# Shell scripts
*.sh         text eol=lf

# Binary files - keep as binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.icns       binary
*.webp       binary
*.woff       binary
*.woff2      binary

# Tauri / Rust
*.lock       -diff
