{
  "name": "digital-twin-platform",
  "version": "3.1.0",
  "private": true,
  "description": "Industrial digital twin platform starter - V1",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.17.1"
  },
  "scripts": {
    "dev": "turbo run dev --filter=!@dt/desktop",
    "dev:all": "turbo run dev --filter=!@dt/web",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --edit",
    "smoke:v2": "bash scripts/smoke-v2.sh",
    "smoke:prod": "bash scripts/smoke-prod.sh",
    "prepare": "lefthook install || true",
    "clean": "turbo run clean && rm -rf node_modules",
    "smoke:permissions": "bash scripts/smoke-permissions.sh",
    "dev:oidc": "node scripts/dev-oidc-idp.mjs",
    "smoke:oidc": "bash scripts/smoke-oidc.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@dt/plugin-runtime": "workspace:*",
    "@types/ws": "^8.18.1",
    "eslint": "^9.15.0",
    "eslint-plugin-vue": "^9.31.0",
    "lefthook": "^1.13.0",
    "prettier": "^3.4.0",
    "tsx": "^4.22.4",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vue-eslint-parser": "^9.4.3",
    "ws": "^8.21.0",
    "jose": "^5.9.6"
  },
  "license": "MIT",
  "author": "zengxiangrong <zengxiangrong@nxin.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/zervero/digital-twin-platform.git",
    "directory": "."
  },
  "homepage": "https://github.com/zervero/digital-twin-platform#readme",
  "bugs": {
    "url": "https://github.com/zervero/digital-twin-platform/issues"
  }
}
