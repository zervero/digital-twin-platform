{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Digital Twin Platform",
  "version": "0.1.0",
  "identifier": "com.digitaltwin.platform",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @dt/web dev",
    "beforeBuildCommand": "pnpm --filter @dt/web build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Digital Twin Platform",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "publisher": "Digital Twin Platform",
    "copyright": [
      "Copyright (c) 2026 Digital Twin Platform"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Digital twin platform desktop shell",
    "longDescription": "Vue 3 + Three.js shell for the digital-twin-platform web app, packaged as a native desktop binary."
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/zervero/digital-twin-platform/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_OUTPUT_OF_TAURI_SIGNER_GENERATE"
    }
  }
}
