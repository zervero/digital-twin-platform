# OpenTelemetry env contract for the web app (V3.1).
#
# V3.1 does NOT ship browser RUM yet — this file is a
# placeholder so the env contract is documented in one place
# before the V3.x feature lands. The web runtime reads these
# via `import.meta.env.VITE_*` at build time; nothing in the
# current web code path reads them, so leaving them unset is
# safe.
#
# When V3.x browser RUM ships:
#   1. Add `@opentelemetry/*` browser packages to apps/web.
#   2. Wire `import.meta.env.VITE_OTEL_*` into a browser
#      tracer provider in `apps/web/src/main.ts`.
#   3. Move the values below from `placeholder` to `required`
#      and update the production nginx.conf + helm chart to
#      inject them at runtime (NOT build time — build-time
#      secrets leak into the bundle).
#
# Until then, leave this file alone. Touching the values
# does nothing.

# OTLP collector endpoint for browser trace export.
# MUST be the public ingestion URL, not the internal one.
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=

# service.name resource attribute.
VITE_OTEL_SERVICE_NAME=digital-twin-platform-web

# deployment.environment.name resource attribute.
VITE_OTEL_DEPLOYMENT_ENVIRONMENT=development
