# OpenTelemetry env contract for the BFF (V3.1).
#
# These are read directly by `@dt/otel` and `apps/bff/src/bootstrap.ts`
# at startup. They are intentionally NOT part of `@dt/config`'s AppEnv:
# the OTel SDK contract is a flat `OTEL_*` namespace, and forcing it
# through our typed config layer would either duplicate the spec or
# drift from it. Keep this file in sync with
# `packages/otel/src/index.ts` if you add a new var there.
#
# Reference: https://opentelemetry.io/docs/specs/otel/configuration/sdk-environment-variables/

# OTLP collector endpoint. The SDK appends `/v1/traces` and
# `/v1/metrics` automatically. Leave unset in local dev to
# default to http://localhost:4318 (an alligator collector).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Overrides the default service.name resource attribute.
# In production we expect the helm chart to leave this unset
# so `@dt/otel`'s hard-coded 'digital-twin-platform-bff' wins
# and matches the chart's Service.name.
OTEL_SERVICE_NAME=digital-twin-platform-bff

# service.version resource attribute. The release pipeline
# sets this via .release-please-manifest.json + the helm
# chart's envFrom; locally it defaults to '0.0.0-dev'.
SERVICE_VERSION=0.0.0-dev

# deployment.environment.name resource attribute.
# Matches the staging / production values the helm chart sets
# from values.yaml. `@dt/otel` reads `DEPLOYMENT_ENVIRONMENT`
# only as a fallback; `apps/bff/src/bootstrap.ts` prefers the
# typed `env.production` flag from `@dt/config`.
DEPLOYMENT_ENVIRONMENT=development

# Periodic metric reader export interval, in milliseconds.
# 30s is a sensible default; tighten to 10s only if your
# dashboards need it because each export is a HTTP POST.
OTEL_METRIC_EXPORT_INTERVAL=30000

# Standard OTel kill switch. When `true`, `@dt/otel`
# returns null from startOtel() and the BFF logs
# "otel disabled" — no SDK, no exporter, zero overhead.
OTEL_SDK_DISABLED=false
